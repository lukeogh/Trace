{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Trace",
  "version": "1.0.9",
  "identifier": "com.trace.app",
  "build": {
    "beforeDevCommand": "npm run dev --prefix frontend",
    "beforeBuildCommand": "npm run build --prefix frontend",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Trace.",
        "width": 1280,
        "height": 860,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "decorations": true,
        "visible": false,
        "url": "about:blank"
      }
    ],
    "trayIcon": {
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": true
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "binaries/trace-backend-x86_64-pc-windows-msvc": "binaries/trace-backend-x86_64-pc-windows-msvc"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "nsis": {
        "installMode": "perMachine",
        "installerHooks": "installer/hooks.nsi"
      }
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ1QkQyODFGQjFBQThDRDIKUldUU2pLcXhIeWk5MVVCc3JqZjR6NmxMQUNCQ09qOTgrUDdvQ3crWnA5cjFTNkp2eElDY3FrakQK",
      "endpoints": [
        "https://github.com/lukeogh/Trace/releases/latest/download/latest.json"
      ]
    }
  }
}
