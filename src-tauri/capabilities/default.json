{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the Trace. desktop shell.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:default",
    "shell:allow-execute",
    "shell:allow-spawn",
    "shell:allow-kill",
    "dialog:allow-open",
    "store:allow-get",
    "store:allow-set",
    "store:allow-save",
    "updater:default",
    "process:allow-restart"
  ]
}
