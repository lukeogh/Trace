{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the Trace. desktop shell.",
  "windows": ["main"],
  "webviews": ["main"],
  "remote": {
    "urls": [
      "http://127.0.0.1:*",
      "http://localhost:*",
      "http://127.0.0.1:*/*",
      "http://localhost:*/*"
    ]
  },
  "permissions": [
    "core:default",
    "allow-get-data-dir",
    "allow-pick-data-dir",
    "allow-migrate-and-set-data-dir",
    "allow-relaunch",
    "allow-get-update-channel",
    "allow-set-update-channel",
    "allow-get-update-endpoint",
    "allow-get-updater-auth-header",
    "shell:default",
    "shell:allow-execute",
    "shell:allow-spawn",
    "shell:allow-kill",
    "dialog:allow-open",
    "store:allow-get",
    "store:allow-set",
    "store:allow-save",
    "updater:default",
    "process:allow-restart"
  ]
}
